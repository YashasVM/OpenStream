<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FF1744" />
            <corners android:radius="@dimen/os_corner_sm" />
            <stroke android:width="1dp" android:color="@color/os_live_red" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1AFF1744" />
            <corners android:radius="@dimen/os_corner_sm" />
            <stroke android:width="1dp" android:color="@color/os_live_red_dim" />
        </shape>
    </item>
</selector>
